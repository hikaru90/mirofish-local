# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
GRAPHITI_LLM_MODEL=gpt-4.1-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 图谱后端配置 =====
# 可选值: zep | graphiti
GRAPH_BACKEND=zep

# 当 GRAPH_BACKEND=graphiti 时使用本地 Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword
# Graphiti embedding 模型（需是当前 LLM 提供商支持的 embedding 模型）
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
LLM_BOOST_EMBEDDING_MODEL=your_embedding_model_here

# ===== Graphiti 第三重试提供商（可选）=====
GRAPHITI_RETRY3_API_KEY=your_api_key_here
GRAPHITI_RETRY3_BASE_URL=your_base_url_here
GRAPHITI_RETRY3_LLM_MODEL=your_model_name_here
GRAPHITI_RETRY3_EMBEDDING_MODEL=your_embedding_model_here